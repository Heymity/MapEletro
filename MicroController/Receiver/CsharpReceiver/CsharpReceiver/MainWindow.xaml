<Window x:Class="CsharpReceiver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CsharpReceiver"
        xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf" 
        xmlns:pt="clr-namespace:PropertyTools.Wpf;assembly=PropertyTools.Wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10*" MinHeight="180"/>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" MinHeight="40" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0">
            <Menu DockPanel.Dock="Top">
                <ComboBox x:Name="ComboBoxPorts" DropDownOpened="ComboBoxPorts_OnDropDownOpened" Width="200" Margin="2"/>
                <MenuItem Header="Conectar" Click="Conectar_Click"/>
                <pt:EnumMenuItem Header="Simulation type" SelectedValue="{Binding SimulationType}"/>
            </Menu>
            <TextBlock DockPanel.Dock="Bottom" Margin="8" Text="{Binding TotalNumberOfPoints, StringFormat='Total number of data points: {0}'}"/>
            <oxy:PlotView x:Name="Plot1" Model="{Binding PlotModel}"/>
        </DockPanel>
        
        <GridSplitter Grid.Row="1"
                      Height="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="Gray"
                      ShowsPreview="True" />
        
        <Grid Grid.Row="2">
            <ScrollViewer x:Name="TerminalScrollView" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="TerminalOutput"
                           FontFamily="Consolas"
                           FontSize="14"
                           Foreground="LightGray"
                           Background="Black"
                           TextWrapping="Wrap"
                           Margin="10"/>
            </ScrollViewer>
        
            <DockPanel VerticalAlignment="Bottom" LastChildFill="True" Margin="10">
                <TextBlock Text="$ " FontFamily="Consolas" Foreground="LightGray" VerticalAlignment="Center"/>
                <TextBox x:Name="CommandInput"
                         FontFamily="Consolas"
                         Background="Black"
                         Foreground="LightGray"
                         BorderThickness="0"
                         KeyDown="CommandInput_KeyDown"
                />
            </DockPanel>
        </Grid>
    </Grid>
</Window>
